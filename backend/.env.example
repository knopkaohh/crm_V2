# Database
DATABASE_URL="postgresql://username:password@localhost:5432/birka_crm?schema=public"

# JWT Authentication
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Server Configuration
PORT=3001
FRONTEND_URL="http://localhost:3000"

# File Upload
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE="52428800"

# Google Sheets cold calls sync
GOOGLE_SHEETS_ID=""
GOOGLE_SHEETS_CONTACTS_TAB="Контакты"
GOOGLE_SERVICE_ACCOUNT_JSON=""
GOOGLE_SERVICE_ACCOUNT_FILE=""
COLD_CALLS_SYNC_CRON="*/2 * * * *"
# Optional: force imported records owner
COLD_CALLS_DEFAULT_USER_ID=""
